# Optional LLM provider configuration for local development.
# MODEL is the provider/model identifier, for example a Microsoft Foundry deployment or model name.
MODEL=

# OPENAI_API_BASE is the OpenAI-compatible endpoint base URL.
OPENAI_API_BASE=

# OPENAI_API_KEY is the secret provider key. Never commit a populated .env file.
OPENAI_API_KEY=

# Optional observability configuration.
# OBSERVABILITY_MODE keeps the default workflow on local in-repo events and metrics.
OBSERVABILITY_MODE=local

# Enable CrewAI ecosystem tracing only after local CrewAI/AMP setup is ready.
# This is optional and is not required for the deterministic MVP.
CREWAI_TRACING_ENABLED=false
